{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account registration and login record",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The unique Firebase Auth user identifier"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User email address"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user was registered"
        },
        "lastLoginAt": {
          "type": "string",
          "format": "date-time",
          "description": "The last timestamp user logged in"
        },
        "sessionInfo": {
          "type": "string",
          "description": "Optional browser session client info"
        }
      },
      "required": ["userId", "email", "createdAt"]
    },
    "Complaint": {
      "title": "Municipal Complaint",
      "description": "Problems and incidents reported by citizens of Yala",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique complaint ID"
        },
        "userId": {
          "type": "string",
          "description": "The reporter's User ID"
        },
        "title": {
          "type": "string",
          "description": "A short heading summarizing the issue"
        },
        "category": {
          "type": "string",
          "description": "Identified category of the problem"
        },
        "description": {
          "type": "string",
          "description": "Thorough explanations of what is damaged"
        },
        "location": {
          "type": "string",
          "description": "Literal address details / landmark coordinates"
        },
        "imageUrl": {
          "type": "string",
          "description": "Image attachment URLs"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "processing", "done", "received", "progress", "completed"],
          "description": "Resolution workflow states"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the issue was submitted"
        },
        "trackingNum": {
          "type": "string",
          "description": "Yala official tracking identifier code"
        },
        "priority": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"],
          "description": "Urgency classification"
        },
        "progressLog": {
          "type": "array",
          "description": "Historical resolution logs list"
        }
      },
      "required": ["id", "userId", "title", "category", "description", "location", "status", "createdAt", "trackingNum", "priority"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Users storage keyed by their unique authentication ID"
    },
    "/complaints/{complaintId}": {
      "schema": "Complaint",
      "description": "Collection of all public municipal complaints"
    }
  }
}
